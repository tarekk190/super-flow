# ═══════════════════════════════════════════════════════════════════════════════
# SperoFlow AI — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.
#
# Get Supabase values from:
#   https://supabase.com/dashboard → your project → Settings → API
# ═══════════════════════════════════════════════════════════════════════════════

# ── Supabase (Auth + Relational Data) ─────────────────────────────────────────
# Project URL — shown on the API settings page (no trailing slash, no /rest/v1/)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/Public key — safe to expose in the browser (RLS enforces data isolation)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Lightning.ai FastAPI Service (AI, Graph & Vector Backend) ──────────────────
# Base URL of your FastAPI service deployed on Lightning.ai (no trailing slash)
LIGHTNING_API_URL=https://your-fastapi-service.lightning.ai

# Optional: service-level API key for the FastAPI service.
# When a user is authenticated, the Supabase JWT is forwarded instead.
LIGHTNING_API_KEY=your-lightning-api-key

# ── FastAPI Brain Orchestrator (LangGraph Central Brain) ──────────────────────
# Defaults to http://localhost:8000 if not set
LIGHTNING_SERVICE_URL=https://your-brain-service.lightning.ai

# ───────────────────────────────────────────────────────────────────────────────
# REMOVED VARIABLES (no longer needed — kept here as a migration reference)
# ───────────────────────────────────────────────────────────────────────────────
# DATABASE_URL  — was used by the legacy node-postgres client (src/utils/db.js)
#                 Replaced by Supabase PostgREST (no direct DB connection needed)
#
# JWT_SECRET    — was used by the legacy custom JWT system (src/utils/auth.js)
#                 Replaced by Supabase Auth session management
